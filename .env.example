# 1) Copiez ce fichier vers .env (à la racine du projet, à côté de manage.py).
# 2) Collez votre clé Tavily ci-dessous (sans guillemets). Elle sera lue à chaque lancement.
#    https://tavily.com/ — tableau de bord → API Keys
# 3) Ne commitez jamais le fichier .env (déjà dans .gitignore).

TAVILY_API_KEY=

# URL publique du site (sans slash final) pour que le lien « confirmer l’e-mail » fonctionne
# depuis n’importe quel appareil. Exemples :
#   http://127.0.0.1:8000
#   https://xxxx.ngrok-free.app
# SITE_URL=

# Optionnel (déjà géré dans config/settings.py)
# DJANGO_DEBUG=1

# --- WaafiPay (abonnements) ---
# Activer sandbox pendant le dev (1) ou production (0)
WAAFI_USE_SANDBOX=1

# Identifiants WaafiPay (fournis lors de la configuration merchant)
WAAFI_MERCHANT_UID=
WAAFI_STORE_ID=
WAAFI_HPP_KEY=

# Optionnel (test / paiement unique) :
# Numéro du payeur à préremplir côté Waafi (format international, ex: +25377353671 ou 25377353671).
WAAFI_PAYER_PHONE=

# Auth API (/asm)
WAAFI_API_USER_ID=
WAAFI_API_KEY=

# Sapling AI detector — clé API (32 caractères)
SAPLING_API_KEY=

# Optionnel : override complet de l'URL /asm
# WAAFI_BASE_URL=https://sandbox.waafipay.net/asm
